<% layout("layouts/boilerplate.ejs") -%>

<div class="row">
  <div class="col-lg-5 col-md-7 mx-auto">
    <div class="auth-card">
      <div class="text-center mb-4">
        <i class="fas fa-sign-in-alt fa-3x mb-3" style="color: #667eea;"></i>
        <h3>Welcome Back</h3>
        <p class="text-muted">Login to manage college events</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="fas fa-exclamation-circle me-2"></i><%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <form method="POST" action="/auth/login" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="email" class="form-label">
            <i class="fas fa-envelope me-2"></i>Email Address
          </label>
          <input type="email" id="email" name="email" class="form-control" placeholder="your.email@college.edu" required>
          <div class="invalid-feedback">Please provide your email.</div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label">
            <i class="fas fa-lock me-2"></i>Password
          </label>
          <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required>
          <div class="invalid-feedback">Please provide your password.</div>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-3">
          <i class="fas fa-sign-in-alt me-2"></i>Login
        </button>

        <div class="text-center">
          <p class="text-muted mb-0">Don't have an account? 
            <a href="/auth/signup" class="text-decoration-none">Sign up here</a>
          </p>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
.auth-card {
  background: white;
  padding: 2.5rem;
  border-radius: 12px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}
</style>