<% layout("layouts/boilerplate.ejs") -%>

<div class="text-center mb-5">
  <h2>🎓 My Registered Events</h2>
  <p class="text-muted">Welcome back, <%= currentUser.name %>!</p>
</div>

<% if (registrations.length === 0) { %>
  <div class="empty-state">
    <i class="fas fa-clipboard-list"></i>
    <h3>No Registrations Yet</h3>
    <p>You haven't registered for any events. Browse available events and register now!</p>
    <a href="/events" class="btn btn-primary mt-3">
      <i class="fas fa-calendar me-2"></i>Browse Events
    </a>
  </div>
<% } else { %>
  <div class="row g-4">
    <% registrations.forEach(reg => { %>
      <% if (reg.eventId) { %>
        <div class="col-lg-4 col-md-6">
          <div class="card">
            <img src="<%= reg.eventId.poster %>" class="card-img-top" alt="<%= reg.eventId.name %>">
            <div class="card-body">
              <span class="category-badge category-<%= reg.eventId.category.toLowerCase() %>">
                <%= reg.eventId.category %>
              </span>
              <h5 class="card-title"><%= reg.eventId.name %></h5>
              <p class="card-text"><%= reg.eventId.description.substring(0, 80) %>...</p>
              
              <div class="mb-3">
                <p class="mb-2">
                  <i class="fas fa-calendar text-primary me-2"></i>
                  <strong>Date:</strong> <%= reg.eventId.date.toDateString() %>
                </p>
                <p class="mb-2">
                  <i class="fas fa-map-marker-alt text-danger me-2"></i>
                  <strong>Venue:</strong> <%= reg.eventId.venue %>
                </p>
                <p class="mb-2">
                  <i class="fas fa-clock text-success me-2"></i>
                  <strong>Registered:</strong> <%= reg.appliedAt.toDateString() %>
                </p>
              </div>
              
              <div class="d-flex gap-2">
                <a href="/events/<%= reg.eventId._id %>" class="btn btn-primary flex-fill">
                  <i class="fas fa-eye me-1"></i>View
                </a>
                <form method="POST" action="/register/<%= reg.eventId._id %>?_method=DELETE" style="flex: 1;">
                  <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Unregister from this event?');">
                    <i class="fas fa-times me-1"></i>Unregister
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    <% }) %>
  </div>
<% } %>