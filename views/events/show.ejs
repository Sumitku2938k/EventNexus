<% layout("layouts/boilerplate.ejs") -%>

<div class="row">
  <div class="col-lg-8 mx-auto">
    <div class="event-detail-card">
      <span class="category-badge category-<%= event.category.toLowerCase() %>">
        <%= event.category %>
      </span>
      
      <h2 class="mt-3 mb-4"><%= event.name %></h2>
      <div class="text-center mb-4">
        <img src="<%= event.poster %>" alt="<%= event.name %> Poster" class="event-poster">
      </div>

      <div class="event-info">
        <div class="info-item">
          <strong><i class="fas fa-align-left me-2"></i> Description:</strong>
          <span><%= event.description %></span>
        </div>
        
        <div class="info-item">
          <strong><i class="fas fa-calendar me-2"></i> Date:</strong>
          <span><%= event.date.toDateString() %></span>
        </div>
        
        <div class="info-item">
          <strong><i class="fas fa-map-marker-alt me-2"></i> Venue:</strong>
          <span><%= event.venue %></span>
        </div>
        
        <div class="info-item">
          <strong><i class="fas fa-rupee-sign me-2"></i> Registration Fee:</strong>
          <span>₹<%= event.registrationFee.toLocaleString("en-IN") %></span>
        </div>
        
        <div class="info-item">
          <strong><i class="fas fa-clock me-2"></i> Posted:</strong>
          <span><%= event.createdAt.toDateString() %></span>
        </div>
      </div>
      
      <div class="action-buttons">
        <!-- Student Registration Button -->
        <% if (currentUser.isLoggedIn && currentUser.role === 'student') { %>
          <% if (isRegistered) { %>
            <form method="POST" action="/register/<%= event._id %>?_method=DELETE">
              <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to unregister?');">
                <i class="fas fa-times-circle me-2"></i>Unregister
              </button>
            </form>
          <% } else { %>
            <form method="POST" action="/register/<%= event._id %>">
              <button type="submit" class="btn btn-success">
                <i class="fas fa-check-circle me-2"></i>Register for Event
              </button>
            </form>
          <% } %>
        <% } %>

        <!-- Admin Actions -->
        <% if (currentUser.role === 'admin') { %>
          <a href="/events/<%= event._id %>/edit" class="btn btn-warning">
            <i class="fas fa-edit me-2"></i>Edit Event
          </a>
          
          <form method="POST" action="/events/<%= event._id %>?_method=DELETE" style="display: inline;">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this event?');">
              <i class="fas fa-trash me-2"></i>Delete Event
            </button>
          </form>

          <a href="/dashboard/admin/event/<%= event._id %>/registrations" class="btn btn-info">
            <i class="fas fa-users me-2"></i>View Registrations
          </a>
        <% } %>
        
        <a href="/events" class="btn btn-primary">
          <i class="fas fa-arrow-left me-2"></i>Back to Events
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Success/Error Messages -->
<% if (typeof success !== 'undefined' && success) { %>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('success') === 'registered') {
        alert('✅ Successfully registered for the event!');
        window.history.replaceState({}, document.title, window.location.pathname);
      } else if (urlParams.get('success') === 'unregistered') {
        alert('✅ Successfully unregistered from the event.');
        window.history.replaceState({}, document.title, window.location.pathname);
      }
    });
  </script>
<% } %>